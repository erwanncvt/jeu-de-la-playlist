{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Cache-Control", "value": "public, max-age=3600" },
        { "key": "Content-Security-Policy", "value": "img-src * data: blob:; frame-src https://www.youtube.com;" }
      ]
    }
  ]
}
